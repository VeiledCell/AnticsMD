# Medical Knowledge Graph (Neo4j AuraDB)
NEO4J_URI=bolt+routing://your-instance.neo4j.io:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Vector DB (ChromaDB)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Cache Database (Supabase / PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# LLM Orchestration
GEMINI_API_KEY=your_gemini_api_key

# Service Config
APP_ENV=development
PORT=8001
